# Prisma Postgres connection string (from the Prisma Postgres / Vercel integration).
DATABASE_URL="prisma+postgres://...."

# Only if your setup needs a direct (non-pooled) URL for migrations:
# DIRECT_URL="postgres://...."

# Vercel Blob store token — used for image/file uploads (@vercel/blob).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_...."

# Session cookie secret for nuxt-auth-utils — must be at least 32 characters.
NUXT_SESSION_PASSWORD="change-me-to-a-min-32-char-random-secret"
